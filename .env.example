# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="RAG Voice Boilerplate"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_WHISPER_MODEL=whisper-1

# ── Vector Store ─────────────────────────────────────────────────────────────
# Options: "chroma" (local, no key) | "pinecone" (cloud)
VECTOR_STORE=chroma

# ChromaDB (local — no API key needed)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# Pinecone (optional — only needed if VECTOR_STORE=pinecone)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX_NAME=rag-index

# ── Re-ranking ────────────────────────────────────────────────────────────────
# Options: "cohere" | "local" | "none"
RERANKER_MODE=local

RETRIEVAL_TOP_K=20
RERANKER_TOP_N=5

# Cohere Rerank (optional — only needed if RERANKER_MODE=cohere)
COHERE_API_KEY=your-cohere-api-key
COHERE_RERANK_MODEL=rerank-english-v3.0

# Local cross-encoder (used when RERANKER_MODE=local — no API key needed)
LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Document Processing ───────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=50
